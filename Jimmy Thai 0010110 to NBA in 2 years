import time
import random

class NBAPlayerSimulator:
    def __init__(self, name):
        self.name = name
        self.year = 2026
        self.is_in_nba = False
        # Starting Stats (Base level)
        self.stats = {
            "Shooting": 65,
            "Athleticism": 70,
            "Defense": 60,
            "Playmaking": 65,
            "Basketball IQ": 75
        }

    def train_season(self, intensity="MAX"):
        """Simulates one year of development."""
        print(f"\n--- Starting {self.year} Training Cycle ---")
        growth_multiplier = 1.5 if intensity == "MAX" else 1.0
        
        for attribute in self.stats:
            # Calculate gains (capped at 99)
            gain = random.randint(10, 15) * growth_multiplier
            self.stats[attribute] = min(99, int(self.stats[attribute] + gain))
            print(f"Improved {attribute} to: {self.stats[attribute]}")
        
        self.year += 1
        time.sleep(1)

    def draft_day(self):
        """Checks if stats are high enough for the NBA."""
        avg_stat = sum(self.stats.values()) / len(self.stats)
        if avg_stat >= 90:
            self.is_in_nba = True
            print(f"\n[DRAFT DAY {self.year}]")
            print(f"With an average stat of {avg_stat:.1f}, {self.name} is the #1 Overall Pick!")
        else:
            print(f"\n{self.name} needs more training. Current Average: {avg_stat:.1f}")

# Execution
jimmy = NBAPlayerSimulator("Jimmy")

# Run 2-year Max Stat Program
for _ in range(2):
    jimmy.train_season(intensity="MAX")

jimmy.draft_day()

print("\nFINAL NBA PROFILE:")
print(f"Year: {jimmy.year} | Status: {'NBA SUPERSTAR' if jimmy.is_in_nba else 'Prospect'}")
print(f"Stats: {jimmy.stats}")

import pandas as pd

# Creating a mock dataset of NBA Stars for 2026
data = {
    'Player': ['Victor Wembanyama', 'Chet Holmgren', 'Nikola Jokic', 'Giannis Antetokounmpo'],
    'Strength': [57, 52, 92, 91],
    'Height_Inches': [89, 85, 83, 83]
}

df = pd.DataFrame(data)

# Apply the 50% strength increase to Wemby
# We use .loc to target the specific player and column
increase_factor = 1.50

df.loc[df['Player'] == 'Victor Wembanyama', 'Strength'] *= increase_factor

# Rounding for a clean 2K-style integer rating
df['Strength'] = df['Strength'].round().astype(int)

print("Updated 2026 Player Stats:")
print(df)

