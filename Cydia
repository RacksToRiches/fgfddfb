import subprocess

def install_cydia_package(package_name):
    print(f"Attempting to install {package_name}...")
    try:
        # Uses APT (the engine behind Cydia)
        result = subprocess.run(['apt-get', 'install', package_name, '-y'], 
                                capture_output=True, text=True)
        if result.returncode == 0:
            print("Success!")
        else:
            print(f"Error: {result.stderr}")
    except FileNotFoundError:
        print("APT not found. Are you running this on a jailbroken device?")

